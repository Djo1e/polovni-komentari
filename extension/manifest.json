{
  "manifest_version": 3,
  "name": "Polovni Komentari",
  "version": "1.7.0",
  "description": "Nezavisni komentari za oglase na polovniautomobili.com",
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "permissions": ["storage", "identity"],
  "oauth2": {
    "client_id": "141307027583-qrnna3sc4gvrnd3eo8v3fp9srrnehtnb.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "host_permissions": [
    "https://www.abs.gov.rs/*",
    "https://www.google-analytics.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.polovniautomobili.com/*"],
      "js": ["src/content/index.tsx"]
    }
  ]
}
